   status = "disabled";
  };

  lpspi1: spi@4009d000 {
   compatible = "nxp,lpspi";
   reg = <0x4009d000 0x1000>;
   interrupts = <29 0>;
   clocks = <&syscon ((0x17 << 8) | (0x01))>;
   tx-fifo-size = <4>;
