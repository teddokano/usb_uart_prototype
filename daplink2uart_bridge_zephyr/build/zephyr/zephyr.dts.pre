   pinmux = <((((('3') - '0') & 0xF) << 28) | (((6) & 0x3F) << 22) | (((5) & 0xF) << 8))>,
     <((((('3') - '0') & 0xF) << 28) | (((7) & 0x3F) << 22) | (((5) & 0xF) << 8))>;
   slew-rate = "fast";
   drive-strength = "low";
  };
 };

 pinmux_i3c0: pinmux_i3c0 {
  group0 {
   pinmux = <((((('0') - '0') & 0xF) << 28) | (((16) & 0x3F) << 22) | (((10) & 0xF) << 8))>,
     <((((('0') - '0') & 0xF) << 28) | (((17) & 0x3F) << 22) | (((10) & 0xF) << 8))>;
   slew-rate = "fast";
   drive-strength = "low";
