&pinctrl {
    pinmux_lpuart2: pinmux_lpuart2 {
        group0 {
            pinmux = <((((('1') - '0') & 0xF) << 28) | (((4) & 0x3F) << 22) | (((3) & 0xF) << 8))>,
                     <((((('1') - '0') & 0xF) << 28) | (((5) & 0x3F) << 22) | (((3) & 0xF) << 8))>;
            slew-rate = "fast";
            drive-strength = "low";
        };
    };
};

