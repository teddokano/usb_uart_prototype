   #address-cells = <1>;
   #size-cells = <0>;
   status = "disabled";
  };

  lptmr0: lptmr@400ab000 {
   compatible = "nxp,lptmr";
   reg = <0x400ab000 0x1000>;
   interrupts = <55 0>;
   clock-frequency = <16000>;
   prescale-glitch-filter = <0>;
   clk-source = <1>;
   resolution = <32>;
   status = "disabled";
  };

  lpuart0: lpuart@4009f000 {
   compatible = "nxp,lpuart";
   status = "disabled";
   reg = <0x4009f000 0x1000>;
   interrupts = <31 0>;
   clocks = <&syscon ((0x13 << 8) | (0x00))>;

   dmas = <&edma0 0 21>, <&edma0 1 22>;
   dma-names = "rx", "tx";
  };

  lpuart1: lpuart@400a0000 {
   compatible = "nxp,lpuart";
   status = "disabled";
   reg = <0x400a0000 0x1000>;
   interrupts = <32 0>;
   clocks = <&syscon ((0x13 << 8) | (0x01))>;

   dmas = <&edma0 2 23>, <&edma0 3 24>;
