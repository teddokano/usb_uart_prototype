   clk-source = <1>;
   clocks = <&syscon 0>;
   mode = <0>;
   input = <0>;
   prescale = <0>;
  };

  ctimer1: ctimer@40005000 {
   compatible = "nxp,lpc-ctimer";
   reg = <0x40005000 0x1000>;
   interrupts = <40 0>;
